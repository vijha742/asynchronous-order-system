        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (topic) (kafka_consumer_fetch_manager_records_lag{job=\"order\"})",
          "legendFormat": "order-service | {{topic}}",
